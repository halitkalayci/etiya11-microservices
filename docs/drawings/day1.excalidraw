      "text": "şu sipariş\ndetayındaki\nürünlerin\nstoklarını düş.",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "gsbcbEiQmNxxk97XkFRLf",
